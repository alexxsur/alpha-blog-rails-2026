<div class="container">
  <div class="row justify-content-center">
    <div class="col-10">
      <%= render 'shared/errors', obj: @article %>
      <%= form_with(model: @article, class: "shadow p-4 mb-4 bg-info rounded", local: true) do |f| %>
        <div class="row mb-3">
          <%= f.label :title, class: "col-sm-2 col-form-label text-light" %>
          <div class="col-sm-10">
            <%= f.text_field :title, class: "form-control shadow-sm rounded", placeholder: "Title of article" %>
          </div>
        </div>

        <div class="row mb-3">
          <%= f.label :description, class: "col-sm-2 col-form-label text-light" %>
          <div class="col-sm-10">
            <%= f.text_area :description, rows: 10, class: "form-control shadow-sm rounded", placeholder: "Description of article" %>
          </div>
        </div>

        <div class="row mb-3">
          <%= f.label :category_ids, "Category", class: "col-2 col-form-label text-light" %>
          <div class="col-10"> 
            <%= f.collection_select(:category_ids, Category.all, :id, :name,
            { prompt: "Make your selection from the list below (can be empty)"}, { multiple: true, size: 3, class: "form-select shadow rounded" }) %>
          </div>
        </div>

        <div class="row justify-content-center">
          <div class="col-auto">
            <%= f.submit class: "btn btn-outline-light btn-lg" %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="col-10 text-center mb-5">
      <%= link_to '[ Cancel and return to articles listing ]', articles_path, class: "text-info text-decoration-none" %>
    </div>
  </div>
</div>
