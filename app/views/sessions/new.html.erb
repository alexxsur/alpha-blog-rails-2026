<h1 class="text-center mt-5">Log in</h1>

<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6"> <%= form_with(scope: :session, url: login_path, class: "shadow p-4 mb-4 bg-info-subtle border border-info-subtle rounded-3", local: true) do |f| %>

        <div class="form-floating mb-3">
          <%= f.email_field :email, class: "form-control shadow-sm", placeholder: "name@example.com" %>
          <%= f.label :email, "Email address" %>
        </div>

        <div class="form-floating mb-4">
          <%= f.password_field :password, class: "form-control shadow-sm", placeholder: "Password" %>
          <%= f.label :password, "Password" %>
        </div>

        <div class="d-grid gap-2"> <%= f.submit "Log in", class: "btn btn-info btn-lg text-white font-weight-bold" %>
        </div>

      <% end %>

      <div class="text-center mb-5">
        <%= link_to '[ Cancel and return to articles listing ]', articles_path, class: "text-info text-decoration-none" %>
      </div>

    </div>
  </div>
</div>