<h1 class="text-center mt-4">Create a new category</h1>

<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-10"> <%= render 'shared/errors', obj: @category %>

      <%= form_with(model: @category, class: "shadow p-4 mb-4 bg-info rounded", local: true) do |f| %>
        <div class="row mb-3 align-items-center">
          <%= f.label :name, "Category name", class: "col-sm-2 col-form-label text-light" %>
          <div class="col-sm-10">
            <%= f.text_field :name, class: "form-control shadow-sm rounded", placeholder: "Enter a name" %>
          </div>
        </div>

        <div class="text-center mt-4">
          <%= f.submit class: "btn btn-outline-light btn-lg" %>
        </div>

      <% end %>

      <div class="text-center mb-3">
        <%= link_to '[ Cancel and return to articles listing ]', articles_path, class: "text-info text-decoration-none" %>
      </div>

    </div>
  </div>
</div>