<h1 class="text-center mt-4">Categories</h1>

<div class="d-flex justify-content-center my-4">
  <div class="flickr_pagination">
    <%= will_paginate @categories, :container => false %>
  </div>
</div>

<div class="container">
  <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4 justify-content-center">
    <% @categories.each do |category| %>
      <div class="col">
        <div class="card text-center shadow h-100 bg-white rounded">
          <div class="card-body d-flex flex-column justify-content-center">
            <h5 class="card-title m-0">
              <%= link_to category.name, category_path(category), class: "text-success text-decoration-none fw-semibold" %>
            </h5>
          </div>
          <div class="card-footer text-muted bg-transparent border-top-0">
            <small class="d-block text-secondary text-opacity-75">
              Created <%= time_ago_in_words(category.created_at) %> ago
            </small>
            <small class="d-block text-secondary text-opacity-75">
              edited <%= time_ago_in_words(category.updated_at) %> ago
            </small>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="d-flex justify-content-center my-4">
  <div class="flickr_pagination mb-4">
    <%= will_paginate @categories, :container => false %>
  </div>
</div>